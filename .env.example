# ─── Public.com API ──────────────────────────────────────────
# Apply at https://public.com/api
PUBLIC_COM_SECRET=your_jwt_secret_here
PUBLIC_COM_ACCOUNT_ID=your_account_id_here
PUBLIC_COM_BASE_URL=https://api.public.com

# ─── Polygon (Massive) ───────────────────────────────────────
POLYGON_API_KEY=your_polygon_api_key_here
POLYGON_REST_BASE=https://api.polygon.io
POLYGON_WS_URL=wss://socket.polygon.io/stocks
POLYGON_INDICES_WS_URL=wss://socket.polygon.io/indices

# ─── Engine config ───────────────────────────────────────────
ENGINE_MODE=DRY_RUN              # DRY_RUN | LIVE_SMALL | LIVE
ENGINE_TIMEZONE=America/New_York
LOG_LEVEL=INFO
SQLITE_PATH=./data/engine.db

# ─── Alerts ──────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=
ALERT_ON_DRY_RUN=true            # log "would have" trades to Discord too

# Optional second channel for verbose gate-evaluation telemetry.
# Leave blank to silence; set to a Discord webhook URL on a separate channel
# (e.g. #harvest-diagnostics) to receive periodic gate-eval snapshots,
# near-miss pings, and a diagnostic EOD summary.
DISCORD_WEBHOOK_DIAGNOSTICS_URL=
DIAGNOSTICS_SNAPSHOT_INTERVAL_S=300   # how often to post snapshots (5 min default)
DIAGNOSTICS_NEAR_MISS_RSI_BAND=5.0    # RSI distance from threshold counted as near-miss
