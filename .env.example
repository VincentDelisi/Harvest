# ─── Public.com API ──────────────────────────────────────────
# Apply at https://public.com/api
PUBLIC_COM_SECRET=your_jwt_secret_here
PUBLIC_COM_ACCOUNT_ID=your_account_id_here
PUBLIC_COM_BASE_URL=https://api.public.com

# ─── Polygon (Massive) ───────────────────────────────────────
POLYGON_API_KEY=your_polygon_api_key_here
POLYGON_REST_BASE=https://api.polygon.io
POLYGON_WS_URL=wss://socket.polygon.io/stocks
POLYGON_INDICES_WS_URL=wss://socket.polygon.io/indices

# ─── Engine config ───────────────────────────────────────────
ENGINE_MODE=DRY_RUN              # DRY_RUN | LIVE_SMALL | LIVE
ENGINE_TIMEZONE=America/New_York
LOG_LEVEL=INFO
SQLITE_PATH=./data/engine.db

# ─── Alerts ──────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=
ALERT_ON_DRY_RUN=true            # log "would have" trades to Discord too
